                }
              },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"case_id\": \"BHA-20260309-abc12345\",\n  \"case_details\": {\n    \"case_id\": \"BHA-20260309-abc12345\",\n    \"subject\": \"agreement.pdf\",\n    \"status\": \"New\",\n    \"priority\": \"Medium\",\n    \"file_count\": 1\n  },\n  \"files\": [\n    {\n      \"file_id\": \"FILE20260309120000abc\",\n      \"original_filename\": \"agreement.pdf\"\n    }\n  ],\n  \"analysis\": {},\n  \"tab_to_display\": \"analyzer\"\n}"
            },
            {
